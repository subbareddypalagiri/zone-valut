# ZoneVault Environment Configuration
# Copy this to .env and update values for local development

# Server Configuration
PORT=8080
HOST=0.0.0.0

# Database Configuration (Auto-set by Railway)
# DATABASE_URL is automatically provided by Railway when you add MySQL
# Format: mysql://user:password@host:port/database

# Local Database (for XAMPP development)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=zonevault
DB_USER=root
DB_PASS=

# Environment
APP_ENV=development
APP_DEBUG=true
